{
  "rewrites": [
    { "source": "/api/create-subscription", "destination": "/api/create-subscription.js" },
    { "source": "/api/verify-subscription",  "destination": "/api/verify-subscription.js"  },
    { "source": "/api/log-events",           "destination": "/api/log-events.js"           }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
